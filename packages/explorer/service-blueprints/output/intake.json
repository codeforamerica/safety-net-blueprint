      "label": "Applicant"
    },
    {
      "id": "caseworker",
      "label": "Caseworker"
    },
    {
      "id": "system",
      "label": "System"
    },
    {
      "id": "regulations",
      "label": "Regulations"
    },
    {
      "id": "data",
      "label": "Events"
    }
  ],
  "phases": [
    {
      "id": "application-intake",
      "label": "Application intake",
      "subPhases": [
        {
          "id": "submitted",
          "label": "Submission"
        }
      ]
    },
    {
      "id": "application-review",
      "label": "Application review",
      "subPhases": [
        {
          "id": "automated-screening",
          "label": "Automated screening"
        },
        {
          "id": "under-review",
          "label": "Task assignment"
        },
        {
          "id": "active-review",
          "label": "Verification review"
        },
        {
          "id": "interview",
          "label": "Program verification"
        }
      ]
    },
    {
      "id": "eligibility-determination",
      "label": "Eligibility determination",
      "subPhases": [
        {
          "id": "benefits-calculation",
          "label": "Determination"
        },
        {
          "id": "decision",
          "label": "Closeout"
        }
      ]
    }
  ],
  "cells": [
    {
      "laneId": "applicant",
      "subPhaseId": "submitted",
      "cards": [
        {
          "type": "person-action",
          "actor": "applicant",
          "text": "Submits application",
          "subtext": "Online or in person; caseworker may submit on behalf of applicant"
        }
      ]
    },
    {
      "laneId": "regulations",
      "subPhaseId": "submitted",
      "cards": [
        {
          "type": "policy",
          "text": "SNAP: 30-day processing clock starts",
          "subtext": "7 CFR § 273.2(g)(1)"
        },
        {
          "type": "policy",
          "text": "Expedited SNAP: 7-day clock",
          "subtext": "If household meets expedited criteria — 7 CFR § 273.2(i)"
        },
        {
          "type": "policy",
          "text": "Medicaid: 45-day clock starts",
          "subtext": "90 days if disability determination needed — 42 CFR § 435.912"
        }
      ]
    },
    {
      "laneId": "data",
      "subPhaseId": "automated-screening",
      "cards": [
        {
          "type": "domain-event",
          "text": "application.submitted",
          "domain": "intake"
        },
        {
          "type": "domain-event",
          "text": "eligibility.application.expedited",
          "domain": "eligibility"
        },
        {
          "type": "domain-event",
          "text": "application.expedited_flagged",
          "domain": "intake"
        },
        {
          "type": "domain-event",
          "text": "eligibility.rte_completed",
          "domain": "eligibility"
        },
        {
          "type": "domain-event",
          "text": "call.completed",
          "domain": "data_exchange"
        },
        {
          "type": "domain-event",
          "text": "person.match_resolved",
          "domain": "client_management"
        }
      ]
    },
    {
      "laneId": "system",
      "subPhaseId": "automated-screening",
      "cards": [
        {
          "type": "system",
          "domain": "workflow",
          "text": "Task created in intake queue; SLA and queue routing assigned",
          "subtext": "In response to event application.submitted"
        },
        {
          "type": "system",
          "domain": "eligibility",
          "text": "Expedited screening initiated",
          "subtext": "Also initiates Medicaid RTE if applicable"
        },
        {
          "type": "system",
          "domain": "intake",
          "text": "Set isExpedited = true on application",
          "subtext": "In response to event eligibility.application.expedited"
        },
        {
          "type": "note",
          "domain": "workflow",
          "text": "⚠ Assign expedited SLA track",
          "subtext": "Expedited SLA type and workflow task switching not yet designed"
        },
        {
          "type": "note",
          "domain": "intake",
          "text": "⚠ Create RTE verification record with Medicaid eligibility outcome",
          "subtext": "rte verification type not yet defined in intake contracts"
        },
        {
          "type": "system",
          "domain": "data_exchange",
          "text": "Federal checks initiated",
          "subtext": "FDSH, IEVS, SAVE, SSA"
        },
        {
          "type": "note",
          "domain": "intake",
          "text": "⚠ Update verification records with federal check results",
          "subtext": "Intake handler for call.completed updating verifications not yet designed"
        },
        {
          "type": "system",
          "domain": "client_management",
          "text": "Person matching initiated",
          "subtext": "In response to event application.submitted"
        },
        {
          "type": "note",
          "domain": "intake",
          "text": "⚠ Auto-confirm exact matches; queue fuzzy matches for caseworker review",
          "subtext": "Person match auto-confirmation behavior not yet designed in intake"
        }
      ]
    },
    {
      "laneId": "caseworker",
      "subPhaseId": "under-review",
      "cards": [
        {
          "type": "person-action",
          "actor": "caseworker",
          "text": "Claims task from queue",
          "subtext": "Caseworker selects from prioritized intake queue"
        },
        {
          "type": "person-action",
          "actor": "caseworker",
          "text": "Schedules interview",
          "subtext": "Launched from within intake — ensures appointment links to application"
        }
      ]
    },
    {
      "laneId": "data",
      "subPhaseId": "under-review",
      "cards": [
        {
          "type": "domain-event",
          "text": "task.claimed",
          "domain": "workflow",
          "subtext": "Application transitions to under_review"
        },
        {
          "type": "domain-event",
          "text": "appointment.scheduled",
          "domain": "scheduling"
        }
      ]
    },
    {
      "laneId": "system",
      "subPhaseId": "under-review",
      "cards": [
        {
          "type": "system",
          "domain": "intake",
          "text": "Interview record created and linked to application",
          "subtext": "In response to event appointment.scheduled"
        }
      ]
    },
    {
      "laneId": "data",
      "subPhaseId": "active-review",
      "cards": [
        {
          "type": "domain-event",
          "text": "call.completed",
          "domain": "data_exchange"
        }
      ]
    },
    {
      "laneId": "caseworker",
      "subPhaseId": "active-review",
      "cards": [
        {
          "type": "person-action",
          "actor": "caseworker",
          "text": "Reviews verification results; resolves satisfied items; flags items needing follow-up",
          "subtext": "Ongoing as results arrive — may trigger document requests or outreach before interview"
        },
        {
          "type": "person-action",
          "actor": "caseworker",
          "text": "Escalates complex case or policy question"
        },
        {
          "type": "person-action",
          "actor": "supervisor",
          "text": "Reviews escalation; provides guidance or takes over resolution"
        }
      ]
    },
    {
      "laneId": "regulations",
      "subPhaseId": "active-review",
      "cards": [
        {
          "type": "policy",
          "text": "Federal verifications required",
          "subtext": "FDSH (citizenship), SAVE (immigration), IEVS (income, SNAP only), SSA (SSN), RTE (existing coverage, Medicaid only) — 42 U.S.C. § 1320b-7"
        },
        {
          "type": "policy",
          "text": "Medicaid: electronic verification before requesting paper documents",
          "subtext": "Ex parte rule — electronic checks must be attempted first; paper documents can only be requested when checks return inconclusive — 42 CFR § 435.911"
        }
      ]
    },
    {
      "laneId": "caseworker",
      "subPhaseId": "interview",
      "cards": [
        {
          "type": "person-action",
          "actor": "caseworker",
          "text": "Conducts interview; resolves remaining verification items"
        }
      ]
    },
    {
      "laneId": "data",
      "subPhaseId": "interview",
      "cards": [
        {
          "type": "domain-event",
          "text": "appointment.completed",
          "domain": "scheduling",
          "subtext": "Interview outcome recorded"
        }
      ]
    },
    {
      "laneId": "regulations",
      "subPhaseId": "interview",
      "cards": [
        {
          "type": "policy",
          "text": "SNAP: Interview required before determination",
          "subtext": "May be waived by state policy — 7 CFR § 273.2(e)"
        },
        {
          "type": "policy",
          "text": "H.R.1: SNAP ABAWD work requirement expansion",
          "subtext": "Expands age range subject to ABAWD work requirements; adds parental work requirements for adults with children above the age threshold — H.R.1 (pending)"
        },
        {
          "type": "policy",
          "text": "H.R.1: Medicaid community engagement requirement",
          "subtext": "Adults required to demonstrate work, volunteering, caregiving, or education hours to maintain Medicaid eligibility — H.R.1 (pending)"
        }
      ]
    },
    {
      "laneId": "data",
      "subPhaseId": "benefits-calculation",
      "cards": [
        {
          "type": "domain-event",
          "text": "application.review_completed",
          "domain": "intake",
          "subtext": "Fires automatically when all VerificationItems are resolved"
        },
        {
          "type": "domain-event",
          "text": "determination_complete",
          "domain": "eligibility"
        }
      ]
    },
    {
      "laneId": "system",
      "subPhaseId": "benefits-calculation",
      "cards": [
        {
          "type": "system",
          "domain": "eligibility",
          "text": "Rules engine invoked",
          "subtext": "Income and expense calculations against household data, per program"
        }
      ]
    },
    {
      "laneId": "caseworker",
      "subPhaseId": "benefits-calculation",
      "cards": [
        {
          "type": "person-action",
          "actor": "caseworker",
          "text": "Reviews determination results",
          "subtext": "Exception review only — not approving a calculation they triggered"
        }
      ]
    },
    {
      "laneId": "regulations",
      "subPhaseId": "benefits-calculation",
      "cards": [
        {
          "type": "policy",
          "text": "SNAP: Determination within 30 days (7 if expedited)",
          "subtext": "7 CFR § 273.2(g)"
        },
        {
          "type": "policy",
          "text": "Medicaid: Determination within 45 days",
          "subtext": "42 CFR § 435.912"
        }
      ]
    },
    {
      "laneId": "caseworker",
      "subPhaseId": "decision",
      "cards": [
        {
          "type": "person-action",
          "actor": "caseworker",
          "text": "Records determination and rationale",
          "subtext": "Eligibility outcome, date, and reasoning recorded per program"
        },
        {
          "type": "person-action",
          "actor": "supervisor",
          "text": "Approves determination",
          "subtext": "Required by state policy; previews notice before sending"
        }
      ]
    },
    {
      "laneId": "data",
      "subPhaseId": "decision",
      "cards": [
        {
          "type": "domain-event",
          "text": "application.closed",
          "domain": "intake"
        }
      ]
    },
    {
      "laneId": "regulations",
      "subPhaseId": "decision",
      "cards": [
        {
          "type": "policy",
          "text": "Notice of Action required",
          "subtext": "Adverse action notice required for denials and closures"
        }
      ]
    }
  ]
}

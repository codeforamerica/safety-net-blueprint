          "type": "person-action",
          "actor": "supervisor",
          "text": "Claims escalated task"
        },
        {
          "type": "person-action",
          "actor": "supervisor",
          "text": "Reviews escalation; provides guidance or takes over resolution"
        }
      ]
    },
    {
      "laneId": "data",
      "subPhaseId": "escalation",
      "cards": [
        {
          "type": "domain-event",
          "text": "task.escalated",

        },
        {
          "type": "domain-event",
          "text": "task.claimed",
          "domain": "workflow"
        }
      ]
    },
    {
      "laneId": "system",
      "subPhaseId": "escalation",
      "cards": [
        {
          "type": "system",
          "domain": "intake",
          "text": "Application status → under supervisor review",
          "subtext": "In response to event task.claimed"
        }
      ]
    },
    {
      "laneId": "caseworker",
      "subPhaseId": "submit-for-determination",
      "cards": [
        {
          "type": "person-action",
          "actor": "caseworker",
          "text": "Submits case for determination",
          "subtext": "Available when all verification items are resolved"
        }
      ]
    },
    {
      "laneId": "system",
      "subPhaseId": "submit-for-determination",
      "cards": [
        {
          "type": "system",
          "domain": "intake",
          "text": "Status updated to pending determination"
        }
      ]
    },
    {
      "laneId": "data",
      "subPhaseId": "submit-for-determination",
      "cards": [
        {
          "type": "domain-event",
          "text": "application.review_completed",
          "domain": "intake"
        }
      ]
    },
    {
      "laneId": "system",
      "subPhaseId": "benefits-calculation",
      "cards": [
        {
          "type": "system",
          "domain": "eligibility",
          "text": "Calculates eligibility",
          "subtext": "Income and expense calculations against household data, per program"
        },
        {
          "type": "system",
          "domain": "intake",
          "text": "Records determination outcome",
          "subtext": "In response to event determination_complete"
        }
      ]
    },
    {
      "laneId": "data",
      "subPhaseId": "benefits-calculation",
      "cards": [
        {
          "type": "domain-event",
          "text": "determination_complete",
          "domain": "eligibility"
        }
      ]
    },
    {
      "laneId": "caseworker",
      "subPhaseId": "benefits-calculation",
      "cards": [
        {
          "type": "person-action",
          "actor": "caseworker",
          "text": "Reviews determination results",
          "subtext": "Exception review only — not approving a calculation they triggered"
        }
      ]
    },
    {
      "laneId": "caseworker",
      "subPhaseId": "decision",
      "cards": [
        {
          "type": "person-action",
          "actor": "caseworker",
          "text": "Records determination and rationale",
          "subtext": "Eligibility outcome, date, and reasoning recorded per program"
        },
        {
          "type": "person-action",
          "actor": "supervisor",
          "text": "Claims task from queue",
          "subtext": "Supervisor selects from supervisor review queue"
        },
        {
          "type": "person-action",
          "actor": "supervisor",
          "text": "Reviews and approves determination",
          "subtext": "If rejected, intake flags for revision and workflow reassigns caseworker task"
        }
      ]
    },
    {
      "laneId": "regulations",
      "subPhaseId": "decision",
      "cards": [
        {
          "type": "policy",
          "text": "SNAP: determination within 30 days (7 if expedited)",
          "subtext": "7 CFR § 273.2(g)"
        },
        {
          "type": "policy",
          "text": "Medicaid: determination within 45 days",
          "subtext": "42 CFR § 435.912"
        },
        {
          "type": "policy",
          "text": "Notice of Action required",
          "subtext": "Adverse action notice required for denials and closures"
        }
      ]
    },
    {
      "laneId": "system",
      "subPhaseId": "decision",
      "cards": [
        {
          "type": "system",
          "domain": "intake",
          "text": "Evaluates if supervisor approval required"
        },
        {
          "type": "system",
          "domain": "workflow",
          "text": "Task created in supervisor review queue; SLA assigned",
          "subtext": "In response to event determination.approval_needed"
        },
        {
          "type": "system",
          "domain": "intake",
          "text": "Determination status → pending approval",
          "subtext": "In response to event task.claimed"
        },
        {
          "type": "system",
          "domain": "communications",
          "text": "Sends Notice of Action",
          "subtext": "Generated from determination outcome; delivered to applicant"
        },
        {
          "type": "system",
          "domain": "case_management",
          "text": "Creates case",
          "subtext": "In response to event application.closed"
        }
      ]
    },

  "cells": [
    {
      "laneId": "applicant",
      "subPhaseId": "submitted",
      "cards": [
        {
          "type": "person-action",
          "actor": "applicant",
          "text": "Submits application",
          "subtext": "Online or in person; caseworker may submit on behalf of applicant"
        }
      ]
    },
    {
      "laneId": "regulations",
      "subPhaseId": "submitted",
      "cards": [
        {
          "type": "policy",
          "text": "SNAP: 30-day processing clock starts",
          "subtext": "7 CFR § 273.2(g)(1)"
        },
        {
          "type": "policy",
          "text": "Expedited SNAP: 7-day clock",
          "subtext": "7 CFR § 273.2(i) — If household meets expedited criteria"
        },
        {
          "type": "policy",
          "text": "Medicaid: 45-day clock starts",
          "subtext": "42 CFR § 435.912 — 90 days if disability determination needed"
        }
      ]
    },
    {
      "laneId": "system",
      "subPhaseId": "submitted",
      "cards": [
        {
          "type": "system",
          "domain": "intake",
          "text": "Documents linked to verification items"
        }
      ]
    },
    {
      "laneId": "system",
      "subPhaseId": "automated-screening",
      "cards": [
        {
          "type": "system",
          "domain": "intake",
          "text": "Verification items and baseline document requirements created"
        },
        {
          "type": "system",
          "domain": "workflow",
          "text": "Task created in intake queue; SLA and queue routing assigned",
          "subtext": "In response to event application.submitted"
        },
        {
          "type": "system",
          "domain": "eligibility",
          "text": "Expedited screening initiated",
          "subtext": "Also initiates Medicaid RTE if applicable"
        },
        {
          "type": "system",
          "domain": "intake",
          "text": "Set isExpedited = true on application",
          "subtext": "In response to event eligibility.application.expedited"
        },
        {
          "type": "note",
          "domain": "workflow",
          "text": "⚠ Assign expedited SLA track",
          "subtext": "Expedited SLA type and workflow task switching not yet designed"
        },
        {
          "type": "system",
          "domain": "eligibility",
          "text": "Medicaid real-time eligibility (RTE) check initiated",
          "subtext": "In response to event application.submitted"
        },
        {
          "type": "note",
          "domain": "intake",
          "text": "⚠ Create RTE verification record with Medicaid eligibility outcome",
          "subtext": "rte verification type not yet defined in intake contracts"
        },
        {
          "type": "system",
          "domain": "data_exchange",
          "text": "Federal checks initiated",
          "subtext": "FDSH, IEVS, SAVE, SSA"
        },
        {
          "type": "note",
          "domain": "intake",
          "text": "⚠ Update verification records with federal check results",
          "subtext": "Intake handler for call.completed updating verifications not yet designed"
        },
        {
          "type": "system",
          "domain": "client_management",
          "text": "Person matching initiated",
          "subtext": "In response to event application.submitted"
        },
        {
          "type": "note",
          "domain": "intake",
          "text": "⚠ Auto-confirm exact matches; queue fuzzy matches for caseworker review",
          "subtext": "Person match auto-confirmation behavior not yet designed in intake"
        }
      ]
    },
    {
      "laneId": "data",
      "subPhaseId": "automated-screening",
      "cards": [
        {
          "type": "domain-event",
          "text": "application.submitted",
          "domain": "intake"
        },
        {
          "type": "domain-event",
          "text": "eligibility.application.expedited",
          "domain": "eligibility"
        },
        {
          "type": "domain-event",
          "text": "application.expedited_flagged",
          "domain": "intake"
        },
        {
          "type": "domain-event",
          "text": "eligibility.rte_completed",
          "domain": "eligibility"
        },
        {
          "type": "domain-event",
          "text": "call.completed",
          "domain": "data_exchange",
          "subtext": "One per service; results arrive asynchronously and in any order"
        },
        {
          "type": "domain-event",
          "text": "person.match_resolved",
          "domain": "client_management"
        }
      ]
    },
    {
      "laneId": "caseworker",
      "subPhaseId": "under-review",
      "cards": [
        {
          "type": "person-action",
          "actor": "caseworker",
          "text": "Claims task from queue",
          "subtext": "Caseworker selects from prioritized intake queue"
        },
        {
          "type": "person-action",
          "actor": "caseworker",
          "text": "Schedules interview",
          "subtext": "Launched from within intake — ensures appointment links to application"
        }
      ]
    },
    {
      "laneId": "data",
      "subPhaseId": "under-review",
      "cards": [
        {
          "type": "domain-event",
          "text": "task.claimed",
          "domain": "workflow"
        },
        {
          "type": "domain-event",
          "text": "appointment.scheduled",
          "domain": "scheduling"
        }
      ]
    },
    {
      "laneId": "system",
      "subPhaseId": "under-review",
      "cards": [
        {
          "type": "system",
          "domain": "intake",
          "text": "Application status → under_review",
          "subtext": "In response to event task.claimed"
        },
        {
          "type": "system",
          "domain": "intake",
          "text": "Interview record created and linked to application",
          "subtext": "In response to event appointment.scheduled"
        }
      ]
    },
    {
      "laneId": "caseworker",
      "subPhaseId": "active-review",
      "cards": [
        {
          "type": "person-action",
          "actor": "caseworker",
          "text": "Reviews verification results; resolves satisfied items; flags unresolved"
        },
        {
          "type": "person-action",
          "actor": "caseworker",
          "text": "Uploads supporting document; attaches to verification item"
        }
      ]
    },
    {
      "laneId": "regulations",
      "subPhaseId": "active-review",
      "cards": [
        {
          "type": "policy",
          "text": "Federal verifications required",
          "subtext": "42 U.S.C. § 1320b-7 — FDSH (citizenship), SAVE (immigration), IEVS (income, SNAP only), SSA (SSN), RTE (existing coverage, Medicaid only)"
        },
        {
          "type": "policy",
          "text": "Medicaid: electronic verification before requesting paper documents",
          "subtext": "42 CFR § 435.911 — Ex parte rule — electronic checks must be attempted first; paper documents can only be requested when checks return inconclusive"
        }
      ]
    },
    {
      "laneId": "system",
      "subPhaseId": "active-review",
      "cards": [
        {
          "type": "system",
          "domain": "intake",
          "text": "Verification item status updated"
        },
        {
          "type": "system",
          "domain": "intake",
          "text": "Document linked to verification item as evidence"
        }
      ]
    },
    {
      "laneId": "data",
      "subPhaseId": "active-review",
      "cards": [
        {
          "type": "domain-event",
          "text": "verification.failed",
          "domain": "intake",
          "subtext": "Communications sends document request notice to applicant"
        }
      ]
    },
    {
      "laneId": "caseworker",
      "subPhaseId": "interview",
      "cards": [
        {
          "type": "person-action",
          "actor": "caseworker",
          "text": "Conducts interview; resolves remaining verification items",
          "subtext": "May require multiple appointments"
        }
      ]
    },
    {
      "laneId": "regulations",
      "subPhaseId": "interview",
      "cards": [
        {
          "type": "policy",
          "text": "SNAP: interview required before determination",
          "subtext": "7 CFR § 273.2(e) — May be waived by state policy"
        },
        {
          "type": "policy",
          "text": "SNAP ABAWD work requirement expansion",
          "subtext": "H.R.1 (pending) — Expands age range subject to work requirements; adds parental requirements for adults with children above the age threshold"
        },
        {
          "type": "policy",
          "text": "Medicaid community engagement requirement",
          "subtext": "H.R.1 (pending) — Adults required to demonstrate work, volunteering, caregiving, or education hours to maintain Medicaid eligibility"
        }
      ]
    },
    {
      "laneId": "data",
      "subPhaseId": "interview",
      "cards": [
        {
          "type": "domain-event",
          "text": "appointment.completed",
          "domain": "scheduling",
          "subtext": "One per appointment; may repeat for multi-session interviews"
        }
      ]
    },
    {
      "laneId": "system",
      "subPhaseId": "interview",
      "cards": [
        {
          "type": "system",
          "domain": "intake",
          "text": "Interview record updated",
          "subtext": "In response to event appointment.completed"
        }
      ]
    },
    {
      "laneId": "caseworker",
      "subPhaseId": "escalation",
      "cards": [
        {
          "type": "person-action",
          "actor": "caseworker",
          "text": "Escalates case"

{
  "id": "intake-blueprint",
  "name": "Intake Service Blueprint",
  "lanes": [
    {
      "id": "applicant",
      "label": "Applicant"
    },
    {
      "id": "caseworker",
      "label": "Caseworker sees"
    },
    {
      "id": "regulations",
      "label": "Program requirements"
    },
    {
      "id": "data-events",
      "label": "Data & events"
    },
    {
      "id": "background",
      "label": "Background system"
    }
  ],
  "phases": [
    {
      "id": "submitted",
      "label": "1 · Submitted",
      "sublabel": "Application in queue"
    },
    {
      "id": "under-review",
      "label": "2 · Under Review",
      "sublabel": "Caseworker claims task"
    },
    {
      "id": "active-review",
      "label": "3 · Active Review",
      "sublabel": "Verifications arriving"
    },
    {
      "id": "interview",
      "label": "4 · Interview",
      "sublabel": "Scheduled appointment"
    },
    {
      "id": "decision",
      "label": "5 · Decision",
      "sublabel": "Eligibility determined"
    }
  ],
  "cells": [
    {
      "laneId": "applicant",
      "phaseId": "submitted",
      "cards": [
        {
          "type": "person-action",
          "actor": "applicant",
          "text": "Submits application",
          "subtext": "Online or in person; starts the regulatory clock"
        },
        {
          "type": "person-action",
          "actor": "applicant",
          "text": "Uploads supporting documents",
          "subtext": "Can happen at any time after submission — before or after caseworker claims"
        }
      ]
    },
    {
      "laneId": "caseworker",
      "phaseId": "submitted",
      "cards": [
        {
          "type": "person-action",
          "actor": "caseworker",
          "text": "Submits application on behalf of applicant",
          "subtext": "In-person or assisted submission"
        }
      ]
    },
    {
      "laneId": "data-events",
      "phaseId": "submitted",
      "cards": [
        {
          "type": "domain-event",
          "text": "application.submitted",
          "subtext": "starts the regulatory clock; triggers caseworker task creation and confirmation notice"
        },
        {
          "type": "data-entity",
          "text": "Application created",
          "subtext": "status: submitted, submittedAt"
        },
        {
          "type": "data-entity",
          "text": "VerificationItems created",
          "subtext": "Income, identity, and residency obligations"
        },
        {
          "type": "data-entity",
          "text": "Workflow task created",
          "subtext": "Added to intake queue"
        }
      ]
    },
    {
      "laneId": "regulations",
      "phaseId": "submitted",
      "cards": [
        {
          "type": "policy",
          "text": "SNAP: 30-day processing clock starts",
          "subtext": "7 CFR § 273.2(g)(1)"
        },
        {
          "type": "policy",
          "text": "Expedited SNAP: 7-day clock",
          "subtext": "If household meets expedited criteria — 7 CFR § 273.2(i)"
        },
        {
          "type": "policy",
          "text": "Medicaid: 45-day clock starts",
          "subtext": "90 days if disability determination needed — 42 CFR § 435.912"
        }
      ]
    },
    {
      "laneId": "background",
      "phaseId": "submitted",
      "cards": [
        {
          "type": "system",
          "text": "Person matching attempted",
          "subtext": "Existing case or record lookup"
        },
        {
          "type": "system",
          "text": "Federal checks initiated",
          "subtext": "FDSH, IEVS, SAVE, SSA"
        },
        {
          "type": "system",
          "text": "Task added to intake queue"
        }
      ]
    },
    {
      "laneId": "caseworker",
      "phaseId": "under-review",
      "cards": [
        {
          "type": "person-action",
          "actor": "caseworker",
          "text": "Claims task and opens the case",
          "subtext": "Full application detail, verification checklist, and interview to schedule become visible"
        },
        {
          "type": "person-action",
          "actor": "caseworker",
          "text": "Schedules interview"
        }
      ]
    },
    {
      "laneId": "data-events",
      "phaseId": "under-review",
      "cards": [
        {
          "type": "domain-event",
          "text": "application.opened",
          "subtext": "signals caseworker has begun active review"
        },
        {
          "type": "domain-event",
          "text": "application.expedited_flagged",
          "subtext": "If applicable — escalates to 7-day SLA track"
        },
        {
          "type": "data-entity",
          "text": "Application updated",
          "subtext": "status: under_review"
        },
        {
          "type": "data-entity",
          "text": "Interview record created"
        }
      ]
    },
    {
      "laneId": "background",
      "phaseId": "under-review",
      "cards": [
        {
          "type": "system",
          "text": "Interview record created"
        },
        {
          "type": "system",
          "text": "Application opened event emitted"
        }
      ]
    },
    {
      "laneId": "regulations",
      "phaseId": "active-review",
      "cards": [
        {
          "type": "policy",
          "text": "Federal verifications required",
          "subtext": "FDSH (citizenship), SAVE (immigration), IEVS (income, SNAP only), SSA (SSN) — 42 U.S.C. § 1320b-7"
        }
      ]
    },
    {
      "laneId": "applicant",
      "phaseId": "active-review",
      "cards": [
        {
          "type": "person-action",
          "actor": "applicant",
          "text": "Responds to verification requests",
          "subtext": "Provides documents or additional information requested by the caseworker"
        }
      ]
    },
    {
      "laneId": "caseworker",
      "phaseId": "active-review",
      "cards": [
        {
          "type": "person-action",
          "actor": "caseworker",
          "text": "Reviews verification results as they arrive",
          "subtext": "FDSH (citizenship), IEVS (income, SNAP), SAVE (immigration), SSA (SSN)"
        },
        {
          "type": "person-action",
          "actor": "caseworker",
          "text": "Follows up on inconclusive checks",
          "subtext": "Requests additional documents when checklist items are added"
        }
      ]
    },
    {
      "laneId": "data-events",
      "phaseId": "active-review",
      "cards": [
        {
          "type": "data-entity",
          "text": "VerificationItems updated",
          "subtext": "Results from FDSH, IEVS, SAVE, SSA — set as results arrive"
        },
        {
          "type": "data-entity",
          "text": "DataExchangeRequests",
          "subtext": "One per federal check; status updates as results return"
        }
      ]
    },
    {
      "laneId": "background",
      "phaseId": "active-review",
      "cards": [
        {
          "type": "system",
          "text": "Verification checklist updated",
          "subtext": "As results arrive — hours to days after submission"
        },
        {
          "type": "system",
          "text": "VerificationItem fields updated",
          "subtext": "Citizenship status (FDSH), immigration status (SAVE)"
        }
      ]
    },
    {
      "laneId": "regulations",
      "phaseId": "interview",
      "cards": [
        {
          "type": "policy",
          "text": "SNAP: Interview required before determination",
          "subtext": "May be waived by state policy — 7 CFR § 273.2(e)"
        }
      ]
    },
    {
      "laneId": "applicant",
      "phaseId": "interview",
      "cards": [
        {
          "type": "person-action",
          "actor": "applicant",
          "text": "Attends interview",
          "subtext": "In person, by phone, or video depending on state policy"
        }
      ]
    },
    {
      "laneId": "caseworker",
      "phaseId": "interview",
      "cards": [
        {
          "type": "person-action",
          "actor": "caseworker",
          "text": "Conducts interview",
          "subtext": "Resolves outstanding documents and inconclusive verification results"
        }
      ]
    },
    {
      "laneId": "data-events",
      "phaseId": "interview",
      "cards": [
        {
          "type": "data-entity",
          "text": "Interview updated",
          "subtext": "Scheduled date, notes, and outcome recorded"
        }
      ]
    },
    {
      "laneId": "background",
      "phaseId": "interview",
      "cards": [
        {
          "type": "system",
          "text": "Interview details recorded"
        }
      ]
    },
    {
      "laneId": "caseworker",
      "phaseId": "decision",
      "cards": [
        {
          "type": "person-action",
          "actor": "caseworker",
          "text": "Makes eligibility determination",
          "subtext": "Applies household size, income, and expense data; records outcome and date"
        },
        {
          "type": "person-action",
          "actor": "supervisor",
          "text": "Approves eligibility determination"
        }
      ]
    },
    {
      "laneId": "data-events",
      "phaseId": "decision",
      "cards": [
        {
          "type": "domain-event",
          "text": "application.closed",
          "subtext": "signals intake is complete; triggers case creation if approved"
        },
        {
          "type": "domain-event",
          "text": "application.review_completed",
          "subtext": "Signals eligibility domain to begin determination — no state change"
        },
        {
          "type": "data-entity",
          "text": "Application updated",
          "subtext": "status: closed, disposition: approved | denied | referred"
        }
      ]
    },
    {
      "laneId": "regulations",
      "phaseId": "decision",
      "cards": [
        {
          "type": "policy",
          "text": "SNAP: Determination within 30 days (7 if expedited)",
          "subtext": "7 CFR § 273.2(g)"
        },
        {
          "type": "policy",
          "text": "Medicaid: Determination within 45 days",
          "subtext": "42 CFR § 435.912"
        },
        {
          "type": "policy",
          "text": "Notice of Action required",
          "subtext": "Adverse action notice required for denials and closures"
        }
      ]
    },
    {
      "laneId": "applicant",
      "phaseId": "decision",
      "cards": [
        {
          "type": "person-action",
          "actor": "applicant",
          "text": "Receives eligibility notice",
          "subtext": "Approval, denial, or pending notice per program"
        }
      ]
    },
    {
      "laneId": "background",
      "phaseId": "decision",
      "cards": [
        {
          "type": "system",
          "text": "SNAP rules engine invoked",
          "subtext": "Income and expense calculations against household data"
        },
        {
          "type": "system",
          "text": "Medicaid MAGI check",
          "subtext": "Real-time via state HIX or eligibility engine"
        },
        {
          "type": "system",
          "text": "Notices generated and queued"
        }
      ]
    }
  ]
}

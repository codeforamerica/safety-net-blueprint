{
  "id": "intake-blueprint",
  "name": "Intake Service Blueprint",
  "lanes": [
    {
      "id": "applicant",
      "label": "Applicant"
    },
    {
      "id": "caseworker",
      "label": "Caseworker"
    },
    {
      "id": "system",
      "label": "Background system"
    },
    {
      "id": "regulations",
      "label": "Regulatory requirements"
    },
    {
      "id": "data",
      "label": "Data & events"
    }
  ],
  "phases": [
    {
      "id": "application-intake",
      "label": "Application intake",
      "subPhases": [
        {
          "id": "awareness",
          "label": "Pre-application"
        },
        {
          "id": "submitted",
          "label": "Submission"
        }
      ]
    },
    {
      "id": "application-review",
      "label": "Application review",
      "subPhases": [
        {
          "id": "automated-screening",
          "label": "Automated screening"
        },
        {
          "id": "under-review",
          "label": "Case assignment"
        },
        {
          "id": "active-review",
          "label": "Data review"
        },
        {
          "id": "interview",
          "label": "Program verification"
        }
      ]
    },
    {
      "id": "eligibility-determination",
      "label": "Eligibility determination",
      "subPhases": [
        {
          "id": "benefits-calculation",
          "label": "Determination"
        },
        {
          "id": "decision",
          "label": "Closeout"
        }
      ]
    }
  ],
  "cells": [
    {
      "laneId": "data",
      "subPhaseId": "awareness",
      "cards": [
        {
          "type": "note",
          "text": "Out of scope for this implementation",
          "subtext": "Outreach, benefit screening, and pre-application triage vary by state. This column is a placeholder for states that want to document this phase alongside intake."
        }
      ]
    },
    {
      "laneId": "applicant",
      "subPhaseId": "submitted",
      "cards": [
        {
          "type": "person-action",
          "actor": "applicant",
          "text": "Submits application",
          "subtext": "Online or in person; starts the regulatory clock"
        }
      ]
    },
    {
      "laneId": "caseworker",
      "subPhaseId": "submitted",
      "cards": [
        {
          "type": "person-action",
          "actor": "caseworker",
          "text": "Submits application on behalf of applicant",
          "subtext": "Assisted or in-person submission"
        }
      ]
    },
    {
      "laneId": "regulations",
      "subPhaseId": "submitted",
      "cards": [
        {
          "type": "policy",
          "text": "SNAP: 30-day processing clock starts",
          "subtext": "7 CFR § 273.2(g)(1)"
        },
        {
          "type": "policy",
          "text": "Expedited SNAP: 7-day clock",
          "subtext": "If household meets expedited criteria — 7 CFR § 273.2(i)"
        },
        {
          "type": "policy",
          "text": "Medicaid: 45-day clock starts",
          "subtext": "90 days if disability determination needed — 42 CFR § 435.912"
        }
      ]
    },
    {
      "laneId": "data",
      "subPhaseId": "submitted",
      "cards": [
        {
          "type": "note",
          "text": "Application record created — not a case",
          "subtext": "A service case is only created if the applicant is approved. Submitted fields are stored as structured data — no PDF, no manual re-entry."
        },
        {
          "type": "domain-event",
          "text": "application.submitted",
          "subtext": "starts the regulatory clock; triggers caseworker task creation and confirmation notice"
        },
        {
          "type": "data-entity",
          "text": "Application created",
          "subtext": "status: submitted, submittedAt, all submitted fields as structured data"
        },
        {
          "type": "data-entity",
          "text": "VerificationItems created",
          "subtext": "Income, identity, and residency obligations — one record per requirement"
        },
        {
          "type": "data-entity",
          "text": "Workflow task created",
          "subtext": "Added to intake queue; automated confirmation sent to applicant"
        }
      ]
    },
    {
      "laneId": "system",
      "subPhaseId": "submitted",
      "cards": [
        {
          "type": "system",
          "text": "Submission confirmation sent to applicant",
          "subtext": "Automated — no manual step required"
        },
        {
          "type": "system",
          "text": "Federal checks initiated",
          "subtext": "FDSH, IEVS, SAVE, SSA — triggered automatically at submission"
        },
        {
          "type": "system",
          "text": "Task added to intake queue"
        }
      ]
    },
    {
      "laneId": "data",
      "subPhaseId": "automated-screening",
      "cards": [
        {
          "type": "domain-event",
          "text": "application.expedited_flagged",
          "subtext": "If applicable — escalates to 7-day SLA track"
        },
        {
          "type": "data-entity",
          "text": "Application updated",
          "subtext": "isExpedited: true, priority: expedited (if flagged)"
        }
      ]
    },
    {
      "laneId": "system",
      "subPhaseId": "automated-screening",
      "cards": [
        {
          "type": "system",
          "text": "Person matching",
          "subtext": "Links application to an existing person or case record if found — no new case is created at submission"
        },
        {
          "type": "system",
          "text": "Eligibility pre-check",
          "subtext": "Screens for expedited criteria and program eligibility indicators"
        },
        {
          "type": "system",
          "text": "Queue routing and SLA assignment",
          "subtext": "Routes to program-specific queue; assigns SLA track per program"
        }
      ]
    },
    {
      "laneId": "caseworker",
      "subPhaseId": "under-review",
      "cards": [
        {
          "type": "person-action",
          "actor": "caseworker",
          "text": "Claims task from queue",
          "subtext": "Application detail, verification checklist, and scheduling become visible"
        },
        {
          "type": "person-action",
          "actor": "caseworker",
          "text": "Schedules interview"
        }
      ]
    },
    {
      "laneId": "data",
      "subPhaseId": "under-review",
      "cards": [
        {
          "type": "domain-event",
          "text": "application.opened",
          "subtext": "signals caseworker has begun active review"
        },
        {
          "type": "data-entity",
          "text": "Application updated",
          "subtext": "status: under_review"
        },
        {
          "type": "data-entity",
          "text": "Interview record created"
        }
      ]
    },
    {
      "laneId": "system",
      "subPhaseId": "under-review",
      "cards": [
        {
          "type": "system",
          "text": "Application opened event emitted"
        }
      ]
    },
    {
      "laneId": "applicant",
      "subPhaseId": "active-review",
      "cards": [
        {
          "type": "person-action",
          "actor": "applicant",
          "text": "Receives notification to submit verification documents (if needed)"
        },
        {
          "type": "person-action",
          "actor": "applicant",
          "text": "Submits verification documents (if needed)"
        }
      ]
    },
    {
      "laneId": "caseworker",
      "subPhaseId": "active-review",
      "cards": [
        {
          "type": "person-action",
          "actor": "caseworker",
          "text": "Reviews application"
        },
        {
          "type": "person-action",
          "actor": "caseworker",
          "text": "Confirms program-agnostic data",
          "subtext": "Demographics, household members, and relationships"
        },
        {
          "type": "person-action",
          "actor": "caseworker",
          "text": "Follows up on inconclusive verification checks",
          "subtext": "Requests additional documents when checklist items remain unresolved"
        }
      ]
    },
    {
      "laneId": "regulations",
      "subPhaseId": "active-review",
      "cards": [
        {
          "type": "policy",
          "text": "Federal verifications required",
          "subtext": "FDSH (citizenship), SAVE (immigration), IEVS (income, SNAP only), SSA (SSN) — 42 U.S.C. § 1320b-7"
        }
      ]
    },
    {
      "laneId": "data",
      "subPhaseId": "active-review",
      "cards": [
        {
          "type": "data-entity",
          "text": "VerificationItems updated",
          "subtext": "Results from FDSH, IEVS, SAVE, SSA — status and result fields updated as results arrive"
        },
        {
          "type": "data-entity",
          "text": "DataExchangeRequests",
          "subtext": "One per federal check; status updates as results return"
        }
      ]
    },
    {
      "laneId": "system",
      "subPhaseId": "active-review",
      "cards": [
        {
          "type": "system",
          "text": "Verification checklist updated automatically",
          "subtext": "As federal results arrive — hours to days after submission"
        }
      ]
    },
    {
      "laneId": "applicant",
      "subPhaseId": "interview",
      "cards": [
        {
          "type": "person-action",
          "actor": "applicant",
          "text": "Attends interview",
          "subtext": "In person, by phone, or video depending on state policy"
        }
      ]
    },
    {
      "laneId": "caseworker",
      "subPhaseId": "interview",
      "cards": [
        {
          "type": "person-action",
          "actor": "caseworker",
          "text": "Conducts program-specific verification",
          "subtext": "Reviews data applicable to each program the applicant applied for"
        },
        {
          "type": "person-action",
          "actor": "caseworker",
          "text": "Conducts SNAP interview"
        },
        {
          "type": "person-action",
          "actor": "caseworker",
          "text": "Resolves remaining verification items",
          "subtext": "Marks inconclusive items resolved or requests final documents"
        }
      ]
    },
    {
      "laneId": "regulations",
      "subPhaseId": "interview",
      "cards": [
        {
          "type": "policy",
          "text": "SNAP: Interview required before determination",
          "subtext": "May be waived by state policy — 7 CFR § 273.2(e)"
        }
      ]
    },
    {
      "laneId": "data",
      "subPhaseId": "interview",
      "cards": [
        {
          "type": "data-entity",
          "text": "Interview updated",
          "subtext": "Scheduled date, notes, and outcome recorded"
        },
        {
          "type": "data-entity",
          "text": "VerificationItems resolved",
          "subtext": "Final status set for each obligation"
        }
      ]
    },
    {
      "laneId": "system",
      "subPhaseId": "interview",
      "cards": [
        {
          "type": "system",
          "text": "Interview details recorded"
        }
      ]
    },
    {
      "laneId": "caseworker",
      "subPhaseId": "benefits-calculation",
      "cards": [
        {
          "type": "person-action",
          "actor": "caseworker",
          "text": "Reviews eligibility calculation results",
          "subtext": "Identifies any unexpected results before recording determination"
        }
      ]
    },
    {
      "laneId": "regulations",
      "subPhaseId": "benefits-calculation",
      "cards": [
        {
          "type": "policy",
          "text": "SNAP: Determination within 30 days (7 if expedited)",
          "subtext": "7 CFR § 273.2(g)"
        },
        {
          "type": "policy",
          "text": "Medicaid: Determination within 45 days",
          "subtext": "42 CFR § 435.912"
        }
      ]
    },
    {
      "laneId": "data",
      "subPhaseId": "benefits-calculation",
      "cards": [
        {
          "type": "domain-event",
          "text": "application.review_completed",
          "subtext": "Signals eligibility domain to begin determination — no intake state change"
        }
      ]
    },
    {
      "laneId": "system",
      "subPhaseId": "benefits-calculation",
      "cards": [
        {
          "type": "system",
          "text": "Rules engine invoked",
          "subtext": "Income and expense calculations against household data, per program"
        }
      ]
    },
    {
      "laneId": "applicant",
      "subPhaseId": "decision",
      "cards": [
        {
          "type": "person-action",
          "actor": "applicant",
          "text": "Receives determination notice",
          "subtext": "Approval, denial, or pending notice per program"
        }
      ]
    },
    {
      "laneId": "caseworker",
      "subPhaseId": "decision",
      "cards": [
        {
          "type": "person-action",
          "actor": "caseworker",
          "text": "Records determination",
          "subtext": "Eligibility outcome and date recorded per program"
        },
        {
          "type": "person-action",
          "actor": "supervisor",
          "text": "Approves determination",
          "subtext": "Required for determinations above supervisor threshold"
        }
      ]
    },
    {
      "laneId": "regulations",
      "subPhaseId": "decision",
      "cards": [
        {
          "type": "policy",
          "text": "Notice of Action required",
          "subtext": "Adverse action notice required for denials and closures"
        }
      ]
    },
    {
      "laneId": "data",
      "subPhaseId": "decision",
      "cards": [
        {
          "type": "data-entity",
          "text": "Application updated",
          "subtext": "status: closed, disposition: approved | denied | referred"
        },
        {
          "type": "domain-event",
          "text": "application.closed",
          "subtext": "signals intake is complete; triggers case creation if approved"
        },
        {
          "type": "domain-event",
          "text": "Event log available",
          "subtext": "Full audit trail of every status change, verification result, and determination"
        }
      ]
    },
    {
      "laneId": "system",
      "subPhaseId": "decision",
      "cards": [
        {
          "type": "system",
          "text": "Notices generated and queued",
          "subtext": "Automated — no manual notice generation step"
        }
      ]
    }
  ]
}

                  "pm.test('event accepted', () => pm.response.to.have.status(202));"
                ]
              }
            }
          ]
        },
        {
          "name": "Verify identity Verification for member A is satisfied",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/intake/applications/{{appId}}/verifications/{{identityVerifIdA}}",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "intake",
                "applications",
                "{{appId}}",
                "verifications",
                "{{identityVerifIdA}}"
              ]
            }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('AC 3 — conclusive result: status satisfied', () => {",
                  "  pm.response.to.have.status(200);",
                  "  const body = pm.response.json();",
                  "  pm.expect(body.status).to.eql('satisfied');",
                  "  pm.expect(body.satisfiedAt).to.be.a('string');",
                  "});",
                  "",
                  "pm.test('AC 3 — electronic evidence item recorded with result: conclusive', () => {",
                  "  const body = pm.response.json();",
                  "  const evidence = body.evidence || [];",
                  "  pm.expect(evidence.length).to.be.greaterThan(0);",
                  "  const item = evidence.find(e => e.type === 'electronic' && e.result === 'conclusive');",
                  "  pm.expect(item).to.exist;",
                  "  pm.expect(item.serviceCallId).to.eql('sc-conclusive-001');",
                  "});"
                ]
              }
            }
          ]
        }
      ]
    },
    {
      "name": "AC 4 — Inconclusive service call result",
      "item": [
        {
          "name": "Inject data_exchange.call.completed (inconclusive) for income/member A",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"specversion\": \"1.0\",\n  \"type\": \"data_exchange.call.completed\",\n  \"source\": \"/test\",\n  \"subject\": \"sc-inconclusive-001\",\n  \"data\": {\n    \"metadata\": { \"intake\": { \"verificationId\": \"{{incomeVerifIdA}}\" } },\n    \"result\": \"inconclusive\",\n    \"serviceCallId\": \"sc-inconclusive-001\",\n    \"serviceType\": \"ssa_ievs\"\n  }\n}",
              "options": {
                "raw": {
                  "language": "json"
                }
              }
            },
            "url": {
              "raw": "{{baseUrl}}/platform/events",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "platform",
                "events"
              ]

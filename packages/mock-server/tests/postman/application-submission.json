    },
    {
      "name": "AC 1+2 — Verifications created at submission",
      "item": [
        {
          "name": "GET verifications for application",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/intake/applications/{{appId}}/verifications?limit=20",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "intake",
                "applications",
                "{{appId}}",
                "verifications"
              ],
              "query": [
                {
                  "key": "limit",
                  "value": "20"
                }
              ]
            }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('13 verifications created (3 members × snap+medicaid)', () => {",
                  "  pm.response.to.have.status(200);",
                  "  const { items, total } = pm.response.json();",
                  "  pm.expect(total).to.eql(13, '3 income + 3 identity + 1 residency + 3 citizenship + 3 immigration');",
                  "});",
                  "",
                  "pm.test('all verifications start as pending', () => {",
                  "  const { items } = pm.response.json();",
                  "  items.forEach(v => pm.expect(v.status).to.eql('pending', `${v.category} (${v.id}) should be pending`));",
                  "});",
                  "",
                  "pm.test('all verifications have empty evidence and documentRequests', () => {",
                  "  const { items } = pm.response.json();",
                  "  items.forEach(v => {",
                  "    pm.expect(v.evidence, `${v.category} evidence`).to.be.an('array').that.is.empty;",
                  "    pm.expect(v.documentRequests, `${v.category} documentRequests`).to.be.an('array');",
                  "  });",
                  "});",
                  "",
                  "pm.test('SNAP: 3 income (electronic) per income source', () => {",
                  "  const { items } = pm.response.json();",
                  "  const income = items.filter(v => v.category === 'income');",
                  "  pm.expect(income.length).to.eql(3);",
                  "  income.forEach(v => pm.expect(v.verificationType).to.eql('electronic'));",
                  "  income.forEach(v => pm.expect(v.sourceType).to.eql('income'));",
                  "  income.forEach(v => pm.expect(v.sourceId).to.be.a('string'));",
                  "  const incomeAId = pm.collectionVariables.get('incomeAId');",
                  "  pm.collectionVariables.set('incomeVerifIdA', (income.find(v => v.sourceId === incomeAId) || {}).id || '');",
                  "});",
                  "",
                  "pm.test('SNAP: 3 identity (electronic) per member', () => {",
                  "  const { items } = pm.response.json();",
                  "  const identity = items.filter(v => v.category === 'identity');",
                  "  pm.expect(identity.length).to.eql(3);",
                  "  identity.forEach(v => pm.expect(v.verificationType).to.eql('electronic'));",
                  "  identity.forEach(v => pm.expect(v.sourceType).to.eql('member'));",
                  "  const memberAId = pm.collectionVariables.get('memberAId');",
                  "  pm.collectionVariables.set('identityVerifIdA', (identity.find(v => v.sourceId === memberAId) || {}).id || '');",
                  "});",
                  "",
                  "pm.test('SNAP: 1 residency (document) at household level — no sourceId', () => {",
                  "  const { items } = pm.response.json();",
                  "  const residency = items.filter(v => v.category === 'residency');",
                  "  pm.expect(residency.length).to.eql(1);",
                  "  pm.expect(residency[0].verificationType).to.eql('document');",
                  "  pm.expect(!residency[0].sourceId).to.be.true;",
                  "  pm.collectionVariables.set('residencyVerifId', residency[0].id);",
                  "});",
                  "",
                  "pm.test('Medicaid: 3 citizenship (electronic) per member', () => {",
                  "  const { items } = pm.response.json();",
                  "  const citizenship = items.filter(v => v.category === 'citizenship');",
                  "  pm.expect(citizenship.length).to.eql(3);",
                  "  citizenship.forEach(v => pm.expect(v.verificationType).to.eql('electronic'));",
                  "  citizenship.forEach(v => pm.expect(v.sourceType).to.eql('member'));",
                  "  citizenship.forEach(v => pm.expect(v.sourceId).to.be.a('string'));",
                  "});",
                  "",
                  "pm.test('Medicaid: 3 immigration (electronic) per member', () => {",
                  "  const { items } = pm.response.json();",
                  "  const immigration = items.filter(v => v.category === 'immigration');",
                  "  pm.expect(immigration.length).to.eql(3);",
                  "  immigration.forEach(v => pm.expect(v.verificationType).to.eql('electronic'));",
                  "  immigration.forEach(v => pm.expect(v.sourceType).to.eql('member'));",
                  "  immigration.forEach(v => pm.expect(v.sourceId).to.be.a('string'));",
                  "});"
                ]
              }
            }
          ]
        },
        {
          "name": "AC 2 — Residency has documentRequests array at creation",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/intake/applications/{{appId}}/verifications/{{residencyVerifId}}",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "intake",
                "applications",
                "{{appId}}",
                "verifications",
                "{{residencyVerifId}}"
              ]
            }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('AC 2 — residency Verification has empty documentRequests before notice', () => {",
                  "  pm.response.to.have.status(200);",
                  "  const body = pm.response.json();",
                  "  pm.expect(body.category).to.eql('residency');",
                  "  pm.expect(body.verificationType).to.eql('document');",
                  "  pm.expect(body.documentRequests).to.be.an('array').that.is.empty;",
                  "});"
                ]
              }
            }
          ]
        },
        {
          "name": "Inject communication.notice.sent (residency)",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"specversion\": \"1.0\",\n  \"type\": \"communication.notice.sent\",\n  \"source\": \"/test\",\n  \"subject\": \"notice-residency-001\",\n  \"data\": {\n    \"noticeId\": \"bbbbbbbb-0001-0001-0001-000000000001\",\n    \"type\": \"document_request_residency_verification\",\n    \"sentAt\": \"2026-01-15T09:00:00Z\",\n    \"metadata\": { \"intake\": { \"verificationId\": \"{{residencyVerifId}}\" } }\n  }\n}",
              "options": {
                "raw": {
                  "language": "json"
                }
              }
            },
            "url": {
              "raw": "{{baseUrl}}/platform/events",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "platform",
                "events"
              ]
            }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('event accepted', () => pm.response.to.have.status(202));"
                ]
              }
            }
          ]
        },
        {
          "name": "Verify residency documentRequests populated",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/intake/applications/{{appId}}/verifications/{{residencyVerifId}}",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "intake",
                "applications",
                "{{appId}}",
                "verifications",
                "{{residencyVerifId}}"
              ]
            }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('AC 2 — residency documentRequests has one entry after notice', () => {",
                  "  pm.response.to.have.status(200);",
                  "  const body = pm.response.json();",
                  "  pm.expect(body.documentRequests).to.be.an('array').with.lengthOf(1);",
                  "  const req = body.documentRequests[0];",
                  "  pm.expect(req.noticeId).to.be.a('string');",
                  "  pm.expect(req.type).to.eql('document_request_residency_verification');",
                  "  pm.expect(req.sentAt).to.be.a('string');",
                  "});"
                ]
              }
            }
          ]
        }
      ]
    },
    {
      "name": "AC 3 — Conclusive service call result",
      "item": [
        {
          "name": "Inject data_exchange.call.completed (conclusive) for identity/member A",
          "request": {
            "method": "POST",
            "header": [

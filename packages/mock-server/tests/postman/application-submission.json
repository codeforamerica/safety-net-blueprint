              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('application submitted — status is submitted, submittedAt set', () => {",
                  "  pm.response.to.have.status(200);",
                  "  const body = pm.response.json();",
                  "  pm.expect(body.status).to.eql('submitted');",

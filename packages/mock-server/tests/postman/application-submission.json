      "name": "Setup",
      "item": [
        {
          "name": "Create application (snap + medicaid)",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              },
              {
                "key": "X-Caller-Id",
                "value": "applicant-1"
              },
              {
                "key": "X-Caller-Roles",
                "value": "applicant"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\"programs\": [\"snap\", \"medicaid\"], \"channel\": \"online\"}",
              "options": {
                "raw": {
                  "language": "json"
                }
              }
            },
            "url": {
              "raw": "{{baseUrl}}/intake/applications",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "intake",
                "applications"
              ]
            }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('application created with status draft', () => {",
                  "  pm.response.to.have.status(201);",
                  "  const body = pm.response.json();",
                  "  pm.expect(body.status).to.eql('draft');",
                  "  pm.expect(body.programs).to.include.members(['snap', 'medicaid']);",
                  "  pm.collectionVariables.set('appId', body.id);",
                  "});"
                ]
              }
            }
          ]
        },

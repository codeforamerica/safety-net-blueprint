#!/usr/bin/env bash
# Pre-push hook: rebuild explorer outputs and commit if stale, then run preflight.
# Skip with: git push --no-verify

set -e

# Skip for delete operations (local SHA is all zeros)
pushing_commits=false
while read local_ref local_sha remote_ref remote_sha; do
  if [ "$local_sha" != "0000000000000000000000000000000000000000" ]; then
    pushing_commits=true
    break
  fi
done
if [ "$pushing_commits" = "false" ]; then
  exit 0
fi

echo ""
echo "Running pre-push checks..."
echo ""

# Rebuild explorer outputs and commit if stale
npm run build --workspace=packages/explorer --silent
if ! git diff --exit-code packages/explorer/ > /dev/null 2>&1; then
  echo "Explorer outputs regenerated — committing..."
  git add packages/explorer/
  git commit -m "Regenerate explorer outputs"
fi

npm run preflight
